#!/usr/bin/env bash
#PBS -N mmdet_test
#PBS -l select=1:ncpus=6:ngpus=1:mem=32gb:gpu_model=A100
#PBS -l walltime=04:00:00
#PBS -M z5428587@ad.unsw.edu.au
#PBS -m abe
#PBS -j oe

set -euo pipefail

module load gcc/11

# Micromamba configuration (override via qsub -v).
export MAMBA_EXE="${MAMBA_EXE:-/srv/scratch/z5428587/mamba/bin/micromamba}"
export MAMBA_ROOT_PREFIX="${MAMBA_ROOT_PREFIX:-/srv/scratch/z5428587/mamba}"
ENV_NAME="${ENV_NAME:-mmdet}"

if [ -x "$MAMBA_EXE" ]; then
    __mamba_setup="$("$MAMBA_EXE" shell hook --shell bash --root-prefix "$MAMBA_ROOT_PREFIX" 2>/dev/null || true)"
    if [ -n "$__mamba_setup" ]; then
        eval "$__mamba_setup"
        micromamba activate "$ENV_NAME" || {
            echo "ERROR: Failed to activate micromamba env: $ENV_NAME"
            exit 1
        }
    else
        echo "ERROR: Failed to initialize micromamba shell hook."
        exit 1
    fi
else
    echo "WARNING: micromamba not found at $MAMBA_EXE. Continuing without activation."
fi

REPO_ROOT="${REPO_ROOT:-${PBS_O_WORKDIR:-$(cd "$(dirname "$0")/.." && pwd)}}"
cd "$REPO_ROOT"

CONFIG_ARG="${1:-}"
CHECKPOINT_ARG="${2:-}"
CONFIG_PATH="${CONFIG_YAML:-${CONFIG:-$CONFIG_ARG}}"
CHECKPOINT_PATH="${CHECKPOINT:-${CKPT:-$CHECKPOINT_ARG}}"

if [ -z "$CONFIG_PATH" ]; then
    echo "Usage:"
    echo "  qsub -V -v \"CONFIG_YAML=<config.py>\" tools/test_single_gpu_planet_nearmap_448.pbs"
    echo "  qsub -V -v \"CONFIG=<config.py>,CHECKPOINT=<checkpoint.pth>\" tools/test_single_gpu_planet_nearmap_448.pbs"
    echo "  qsub tools/test_single_gpu_planet_nearmap_448.pbs -- <config.py> [checkpoint.pth]"
    exit 1
fi

if [ ! -f "$CONFIG_PATH" ]; then
    if [ -f "$REPO_ROOT/$CONFIG_PATH" ]; then
        CONFIG_PATH="$REPO_ROOT/$CONFIG_PATH"
    else
        echo "ERROR: Config file not found: $CONFIG_PATH"
        exit 1
    fi
fi

RUN_NAME="$(basename "${CONFIG_PATH%.py}")"
WORK_DIR_BASE="${WORK_DIR_BASE:-/srv/scratch/z5428587/runs/mmdet/segment}"
RUN_DIR="${WORK_DIR_BASE%/}/${RUN_NAME}"
export WANDB_NAME="${WANDB_NAME:-$RUN_NAME}"

if [ -z "$CHECKPOINT_PATH" ]; then
    CHECKPOINT_PATH="$(ls -1t "$RUN_DIR"/best*.pth 2>/dev/null | head -n 1 || true)"
    if [ -z "$CHECKPOINT_PATH" ] && [ -f "$RUN_DIR/latest.pth" ]; then
        CHECKPOINT_PATH="$RUN_DIR/latest.pth"
    elif [ -z "$CHECKPOINT_PATH" ]; then
        CHECKPOINT_PATH="$(ls -1t "$RUN_DIR"/epoch_*.pth 2>/dev/null | head -n 1 || true)"
    fi
fi

if [ -z "$CHECKPOINT_PATH" ] || [ ! -f "$CHECKPOINT_PATH" ]; then
    echo "ERROR: Checkpoint not found."
    echo "Provide CHECKPOINT explicitly or ensure one exists in: $RUN_DIR"
    exit 1
fi

TEST_WORK_DIR="${TEST_WORK_DIR:-${RUN_DIR}/test_artifacts}"
mkdir -p "$TEST_WORK_DIR"
OUT_FILE="${OUT_FILE:-${TEST_WORK_DIR}/predictions.pkl}"
EMAIL_TO="${EMAIL_TO:-z5428587@ad.unsw.edu.au}"
JOB_TAG="${PBS_JOBID:-manual_$$}"
STDOUT_LOG="${TEST_WORK_DIR}/${RUN_NAME}_${JOB_TAG}.out.log"
STDERR_LOG="${TEST_WORK_DIR}/${RUN_NAME}_${JOB_TAG}.err.log"

EXTRA_ARGS=()
if [ $# -gt 2 ]; then
    EXTRA_ARGS=("${@:3}")
fi

send_failure_email() {
    local exit_code="$1"
    local subject="MMDet PBS FAILED: test ${RUN_NAME} (job ${PBS_JOBID:-N/A})"
    local body_file
    body_file="$(mktemp)"

    {
        echo "MMDetection testing failed."
        echo "Time: $(date)"
        echo "Job ID: ${PBS_JOBID:-N/A}"
        echo "Host: $(hostname)"
        echo "Repo: $REPO_ROOT"
        echo "Config: $CONFIG_PATH"
        echo "Checkpoint: $CHECKPOINT_PATH"
        echo "Test work dir: $TEST_WORK_DIR"
        echo "Out file: $OUT_FILE"
        echo "Exit code: $exit_code"
        echo "Stdout log: $STDOUT_LOG"
        echo "Stderr log: $STDERR_LOG"
        echo
        echo "Command:"
        printf '  %q' "${cmd[@]}"
        echo
        echo
        echo "----- BEGIN STDERR (full) -----"
        if [ -s "$STDERR_LOG" ]; then
            cat "$STDERR_LOG"
        else
            echo "(stderr log is empty)"
        fi
        echo "----- END STDERR -----"
    } > "$body_file"

    if command -v mail >/dev/null 2>&1; then
        mail -s "$subject" "$EMAIL_TO" < "$body_file"
    elif command -v mailx >/dev/null 2>&1; then
        mailx -s "$subject" "$EMAIL_TO" < "$body_file"
    elif command -v sendmail >/dev/null 2>&1; then
        {
            echo "To: $EMAIL_TO"
            echo "Subject: $subject"
            echo
            cat "$body_file"
        } | sendmail -t
    else
        echo "WARNING: No mail tool found (mail/mailx/sendmail). Cannot send failure email."
        echo "Failure details are in: $STDERR_LOG"
    fi

    rm -f "$body_file"
}

echo "========================================="
echo "Job started at: $(date)"
echo "Job ID: ${PBS_JOBID:-N/A}"
echo "Node: $(hostname)"
echo "Repo root: $REPO_ROOT"
echo "Config: $CONFIG_PATH"
echo "Checkpoint: $CHECKPOINT_PATH"
echo "Test work dir: $TEST_WORK_DIR"
echo "Output pkl: $OUT_FILE"
echo "W&B run name: $WANDB_NAME"
echo "Single-node/single-GPU: yes"
echo "Python: $(which python)"
echo "Python version: $(python --version 2>&1)"
echo "GPU information:"
nvidia-smi || echo "Warning: nvidia-smi not available"
echo "========================================="

export PYTHONPATH="$REPO_ROOT:${PYTHONPATH:-}"
cmd=(
    python tools/test.py
    "$CONFIG_PATH"
    "$CHECKPOINT_PATH"
    --work-dir "$TEST_WORK_DIR"
    --out "$OUT_FILE"
)

if [ "${#EXTRA_ARGS[@]}" -gt 0 ]; then
    cmd+=("${EXTRA_ARGS[@]}")
fi

echo "Command:"
printf '  %q' "${cmd[@]}"
echo

: > "$STDOUT_LOG"
: > "$STDERR_LOG"

set +e
"${cmd[@]}" >> "$STDOUT_LOG" 2>> "$STDERR_LOG"
test_exit=$?
set -e

if [ "$test_exit" -ne 0 ]; then
    echo "Testing failed with exit code $test_exit"
    echo "----- BEGIN STDERR (full) -----"
    cat "$STDERR_LOG"
    echo "----- END STDERR -----"
    send_failure_email "$test_exit" || true
    exit "$test_exit"
fi

echo "Testing completed successfully."
echo "Predictions written to: $OUT_FILE"
echo "Stdout log: $STDOUT_LOG"
echo "Stderr log: $STDERR_LOG"
